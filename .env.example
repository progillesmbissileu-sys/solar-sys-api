TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app
DRIVE_DISK=fs

# ─── Storage provider ────────────────────────────────────────────────────────
# Set to LOCAL or RAILWAY
STORAGE_PROVIDER=LOCAL
STORAGE_BASE_PATH=uploads
IMAGE_STORAGE_BASE_PATH=images
DOCUMENT_STORAGE_BASE_PATH=documents

# ─── Local storage (used when STORAGE_PROVIDER=LOCAL) ────────────────────────
LOCAL_STORAGE_PATH=./storage/uploads
LOCAL_STORAGE_URL=http://localhost:3333/uploads

# ─── Railway object storage (used when STORAGE_PROVIDER=RAILWAY) ─────────────
# All values are provided by Railway when you add an Object Storage service.
# The backend does NOT serve these files — clients access them via the public URL.
RAILWAY_STORAGE_ENDPOINT=https://t3.storageapi.dev
