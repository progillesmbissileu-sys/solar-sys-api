meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/register
  body: json
  auth: none
}

body:json {
  {
    "email": "admin-dev@admin.com",
    "password": "admin-pwd",
    "fullName": "Test User"
  }
}

tests {
  test("should return 201 on success", function() {
    expect(res.status).toBe(201);
  });
  
  test("should return access token", function() {
    const body = res.body;
    expect(body.data.accessToken).toBeTruthy();
  });
}
