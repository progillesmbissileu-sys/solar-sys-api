meta {
  name: Get Category
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/product-category/{{category_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

vars:pre-request {
  category_id: 1ed8aa22-d39e-4a6e-b6c3-6cc0437f5ec9
}

tests {
  test("should return 202 on success", function() {
    expect(res.status).toBe(202);
  });
  
  test("should return category data", function() {
    const body = res.body;
    expect(body.data).toBeTruthy();
  });
}
